# ── Model settings ──────────────────────────────────────────────
GENERATOR_MODEL=Gautamo1/mistral-7b-rag-reader
EMBED_MODEL=BAAI/bge-base-en-v1.5

# ── Device (ROCm 7.0 / PyTorch 2.9 confirmed) ───────────────────
DEVICE_MAP=auto
TORCH_DTYPE=bfloat16
COMPILE_MODEL=true

# ── Retrieval ────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=8
INDEX_PATH=data/index/faiss.index
CHUNKS_PATH=data/index/chunks.json

# ── API ──────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=1

# ── Generation ───────────────────────────────────────────────────
MAX_NEW_TOKENS=512
TEMPERATURE=0.1
DO_SAMPLE=false
