# ── Model settings ──────────────────────────────────────────────
GENERATOR_MODEL=Gautamo1/mistral-7b-rag-reader
# bge-base fits easily on GPU alongside the 7B model — higher accuracy than bge-small
EMBED_MODEL=BAAI/bge-base-en-v1.5

# ── Device (AMD MI300X / ROCm) ───────────────────────────────────
DEVICE_MAP=auto
TORCH_DTYPE=bfloat16
# torch.compile gives ~20-30% throughput on ROCm
# set false only if you hit a ROCm version incompatibility on first run
COMPILE_MODEL=true

# ── Retrieval ────────────────────────────────────────────────────
CHUNK_SIZE=512
CHUNK_OVERLAP=64
TOP_K=8
INDEX_PATH=data/index/faiss.index
CHUNKS_PATH=data/index/chunks.json

# ── API ──────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Each worker loads its own copy of the model (~14 GB per worker)
# With 192 GB VRAM you could run up to ~10 workers
API_WORKERS=1

# ── Generation ───────────────────────────────────────────────────
MAX_NEW_TOKENS=512
TEMPERATURE=0.1
DO_SAMPLE=false
